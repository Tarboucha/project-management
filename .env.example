# Supabase
NEXT_PUBLIC_SUPABASE_URL=https://your-project.supabase.co
NEXT_PUBLIC_SUPABASE_PUBLISHABLE_KEY=sb_publishable_your-key-here

# Database (session-mode pooler)
DATABASE_URL=postgresql://postgres.your-project:password@aws-1-eu-west-1.pooler.supabase.com:5432/postgres?sslmode=require

# Local development alternative
# DATABASE_URL=postgresql://postgres:password@localhost:5432/ppm?sslmode=disable

# Auth
SUPABASE_JWT_SECRET=your-jwt-secret
