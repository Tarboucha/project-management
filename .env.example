# ============================================================
# PPM — Environment Variables
# ============================================================
# Copy this file to .env and fill in your values.
#
# Option A: Local PostgreSQL
#   DATABASE_URL=postgresql://ppm_app:<password>@localhost:5432/ppm
#   DATABASE_URL_MIGRATE=postgresql://postgres:<password>@localhost:5432/ppm
#
# Option B: Supabase (see docs/supabase-setup.md)
#   DATABASE_URL=postgresql://ppm_app.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:6543/postgres
#   DATABASE_URL_MIGRATE=postgresql://postgres.<project-ref>:<password>@aws-0-<region>.pooler.supabase.com:5432/postgres
# ============================================================

# Database — app connects as restricted ppm_app role (no DELETE, no DDL)
DATABASE_URL=postgresql://ppm_app:your-password@localhost:5432/ppm
# Superuser — used only for migrations and DB setup
DATABASE_URL_MIGRATE=postgresql://postgres:your-password@localhost:5432/ppm

# Auth
JWT_SECRET=generate-a-random-hex-string-here   # Generate with: openssl rand -hex 48
JWT_EXPIRES_IN=10800                            # Token lifetime in seconds (default: 3 hours)

# Rate Limiting
RATE_LIMIT_LOGIN_MAX=10
RATE_LIMIT_LOGIN_WINDOW_MS=900000
RATE_LIMIT_SIGNUP_MAX=5
RATE_LIMIT_SIGNUP_WINDOW_MS=900000


