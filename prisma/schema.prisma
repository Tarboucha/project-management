generator client {
  provider        = "prisma-client"
  output          = "../src/generated/prisma"
  previewFeatures = ["partialIndexes"]
}

datasource db {
  provider = "postgresql"
  schemas  = ["public"]
}

// ============================================================
// PUBLIC ENUMS
// ============================================================

enum SystemRole {
  ADMIN
  USER

  @@map("system_role")
  @@schema("public")
}

enum ProjectRole {
  DIRECTOR
  MANAGER
  CONTRIBUTOR

  @@map("project_role")
  @@schema("public")
}

enum EntityState {
  ACTIVE
  ENDED

  @@map("entity_state")
  @@schema("public")
}

enum TodoStatus {
  ACTIVE
  INACTIVE

  @@map("todo_status")
  @@schema("public")
}

enum TaskPriority {
  LOW
  NORMAL
  MEDIUM
  HIGH
  URGENT

  @@map("task_priority")
  @@schema("public")
}

enum AuditAction {
  CREATE
  UPDATE
  END
  DELETE

  @@map("audit_action")
  @@schema("public")
}

// ============================================================
// LOOKUP TABLES
// ============================================================

model Activity {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @unique @db.VarChar(50)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt  DateTime? @map("modified_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  projects Project[]

  @@map("activity")
  @@schema("public")
}

model Theme {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @unique @db.VarChar(50)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt  DateTime? @map("modified_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  projects Project[]

  @@map("theme")
  @@schema("public")
}

model Category {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String    @db.VarChar(255)
  code        String    @unique @db.VarChar(50)
  description String?
  isActive    Boolean   @default(true) @map("is_active")
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt  DateTime? @map("modified_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  projects Project[]

  @@map("category")
  @@schema("public")
}

// ============================================================
// ACTOR
// ============================================================

model Actor {
  id           String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  firstName    String     @map("first_name") @db.VarChar(100)
  lastName     String     @map("last_name") @db.VarChar(100)
  email        String     @unique @db.VarChar(255)
  passwordHash String     @map("password_hash")
  systemRole   SystemRole @default(USER) @map("system_role")
  isActive     Boolean    @default(true) @map("is_active")
  fromAd       Boolean    @default(false) @map("from_ad")
  hourlyRate   Decimal?   @map("hourly_rate") @db.Decimal(8, 2)
  createdAt    DateTime   @default(now()) @map("created_at") @db.Timestamptz(6)
  updatedAt    DateTime   @default(now()) @updatedAt @map("updated_at") @db.Timestamptz(6)
  deletedAt    DateTime?  @map("deleted_at") @db.Timestamptz(6)

  // Relations
  auditLogs           AuditLog[]
  createdDeliverables Deliverable[]     @relation("DeliverableCreatedBy")
  createdPrograms     Program[]         @relation("ProgramCreatedBy")
  createdProjects     Project[]         @relation("ProjectCreatedBy")
  projectMembers      ProjectMember[]
  createdTasks        Task[]            @relation("TaskCreatedBy")
  ownedTasks          Task[]            @relation("TaskOwner")
  timeEntries         TimeEntry[]
  todosResponsible    Todo[]            @relation("TodoResponsible")
  todosCreated        Todo[]            @relation("TodoCreatedBy")
  uploadedAttachments Attachment[]      @relation("AttachmentUploadedBy")
  createdReviews      Review[]          @relation("ReviewCreatedBy")

  @@index([email], map: "idx_actor_email")
  @@index([isActive], map: "idx_actor_is_active", where: raw("(deleted_at IS NULL)"))
  @@index([systemRole], map: "idx_actor_system_role")
  @@map("actor")
  @@schema("public")
}

// ============================================================
// PROGRAM
// ============================================================

model Program {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String      @db.VarChar(255)
  description     String?
  version         Int         @default(1)
  state           EntityState @default(ACTIVE)
  startDate       DateTime    @map("start_date") @db.Date
  endDate         DateTime?   @map("end_date") @db.Date
  budgetEstimated Decimal?    @map("budget_estimated") @db.Decimal(12, 2)
  currency        String?     @default("EUR") @db.VarChar(3)
  createdById     String      @map("created_by_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt      DateTime?   @map("modified_at") @db.Timestamptz(6)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)

  // Relations
  createdBy Actor     @relation("ProgramCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  projects  Project[]

  @@index([createdById], map: "idx_program_created_by")
  @@index([state], map: "idx_program_state", where: raw("(deleted_at IS NULL)"))
  @@map("program")
  @@schema("public")
}

// ============================================================
// PROJECT
// ============================================================

model Project {
  id              String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name            String      @db.VarChar(255)
  projectCode     String?     @map("project_code")
  objective       String?
  programId       String      @map("program_id") @db.Uuid
  activityId      String?     @map("activity_id") @db.Uuid
  themeId         String?     @map("theme_id") @db.Uuid
  categoryId      String?     @map("category_id") @db.Uuid
  version         Int         @default(1)
  state           EntityState @default(ACTIVE)
  progress        Int         @default(0) @db.SmallInt
  startDate       DateTime    @map("start_date") @db.Date
  endDate         DateTime?   @map("end_date") @db.Date
  budgetEstimated Decimal?    @map("budget_estimated") @db.Decimal(12, 2)
  createdById     String      @map("created_by_id") @db.Uuid
  createdAt       DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt      DateTime?   @map("modified_at") @db.Timestamptz(6)
  deletedAt       DateTime?   @map("deleted_at") @db.Timestamptz(6)

  // Relations
  activity   Activity?       @relation(fields: [activityId], references: [id], onDelete: SetNull)
  category   Category?       @relation(fields: [categoryId], references: [id], onDelete: SetNull)
  theme      Theme?          @relation(fields: [themeId], references: [id], onDelete: SetNull)
  createdBy  Actor           @relation("ProjectCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  program    Program         @relation(fields: [programId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  members    ProjectMember[]
  tasks      Task[]
  todos      Todo[]
  reviews    Review[]
  auditLogs  AuditLog[]

  @@index([createdById], map: "idx_project_created_by")
  @@index([programId], map: "idx_project_program")
  @@index([state], map: "idx_project_state", where: raw("(deleted_at IS NULL)"))
  @@index([activityId])
  @@index([categoryId])
  @@index([themeId])
  @@map("project")
  @@schema("public")
}

// ============================================================
// PROJECT MEMBER
// ============================================================

model ProjectMember {
  id         String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId  String      @map("project_id") @db.Uuid
  actorId    String      @map("actor_id") @db.Uuid
  role       ProjectRole
  assignedAt DateTime    @default(now()) @map("assigned_at") @db.Timestamptz(6)
  deletedAt  DateTime?   @map("deleted_at") @db.Timestamptz(6)

  // Relations
  actor   Actor   @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, actorId])
  @@index([actorId], map: "idx_project_member_actor")
  @@index([projectId, role], map: "idx_project_member_role")
  @@map("project_member")
  @@schema("public")
}

// ============================================================
// TASK
// ============================================================

model Task {
  id              String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  objective       String       @db.VarChar(255)
  details         String?
  projectId       String       @map("project_id") @db.Uuid
  priority        TaskPriority @default(NORMAL)
  version         Int          @default(1)
  state           EntityState  @default(ACTIVE)
  progress        Int          @default(0) @db.SmallInt
  taskOrder       Int          @default(0) @map("task_order")
  startDate       DateTime     @map("start_date") @db.Date
  endDate         DateTime?    @map("end_date") @db.Date
  budgetEstimated Decimal?     @map("budget_estimated") @db.Decimal(12, 2)
  ownerId         String?      @map("owner_id") @db.Uuid
  createdById     String       @map("created_by_id") @db.Uuid
  createdAt       DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt      DateTime?    @map("modified_at") @db.Timestamptz(6)
  deletedAt       DateTime?    @map("deleted_at") @db.Timestamptz(6)

  // Relations
  owner        Actor?            @relation("TaskOwner", fields: [ownerId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy    Actor             @relation("TaskCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project      Project           @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  deliverables Deliverable[]
  timeEntries  TimeEntry[]
  auditLogs    AuditLog[]

  @@index([ownerId], map: "idx_task_owner")
  @@index([createdById], map: "idx_task_created_by")
  @@index([projectId, taskOrder], map: "idx_task_order")
  @@index([projectId, priority], map: "idx_task_priority")
  @@index([projectId], map: "idx_task_project", where: raw("(deleted_at IS NULL)"))
  @@index([projectId, state], map: "idx_task_state", where: raw("(deleted_at IS NULL)"))
  @@map("task")
  @@schema("public")
}

// ============================================================
// TODO
// ============================================================

model Todo {
  id             String     @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId      String     @map("project_id") @db.Uuid
  todoOrder      Int        @default(0) @map("todo_order")
  action         String
  status         TodoStatus @default(ACTIVE)
  deliveryDate   DateTime?  @map("delivery_date") @db.Date
  responsibleId  String?    @map("responsible_id") @db.Uuid
  comments       String?
  createdById    String     @map("created_by_id") @db.Uuid
  version        Int        @default(1)
  createdAt      DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt     DateTime? @map("modified_at") @db.Timestamptz(6)
  deletedAt      DateTime? @map("deleted_at") @db.Timestamptz(6)

  project     Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  responsible Actor?  @relation("TodoResponsible", fields: [responsibleId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  createdBy   Actor   @relation("TodoCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@unique([projectId, todoOrder], map: "idx_todo_project_order")
  @@index([responsibleId], map: "idx_todo_responsible")
  @@index([createdById], map: "idx_todo_created_by")
  @@map("todo")
  @@schema("public")
}

// ============================================================
// TIME ENTRY
// ============================================================

model TimeEntry {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  taskId      String    @map("task_id") @db.Uuid
  actorId     String    @map("actor_id") @db.Uuid
  hours       Decimal   @db.Decimal(5, 2)
  hourlyRate  Decimal?  @map("hourly_rate") @db.Decimal(8, 2)
  description String?
  workDate    DateTime  @map("work_date") @db.Date
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt  DateTime? @map("modified_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)

  // Relations
  actor Actor @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task  Task  @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([actorId], map: "idx_time_entry_actor", where: raw("(deleted_at IS NULL)"))
  @@index([taskId], map: "idx_time_entry_task", where: raw("(deleted_at IS NULL)"))
  @@index([taskId, actorId], map: "idx_time_entry_task_actor", where: raw("(deleted_at IS NULL)"))
  @@index([workDate], map: "idx_time_entry_work_date")
  @@map("time_entry")
  @@schema("public")
}

// ============================================================
// DELIVERABLE
// ============================================================

model Deliverable {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name        String       @db.VarChar(255)
  type        String?      @db.VarChar(100)
  taskId      String       @map("task_id") @db.Uuid
  version     Int          @default(1)
  createdById String       @map("created_by_id") @db.Uuid
  createdAt   DateTime     @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt  DateTime?    @map("modified_at") @db.Timestamptz(6)
  deletedAt   DateTime?    @map("deleted_at") @db.Timestamptz(6)

  // Relations
  attachments Attachment[]
  createdBy   Actor        @relation("DeliverableCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task        Task         @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([createdById], map: "idx_deliverable_created_by")
  @@index([taskId], map: "idx_deliverable_task", where: raw("(deleted_at IS NULL)"))
  @@map("deliverable")
  @@schema("public")
}

// ============================================================
// ATTACHMENT
// ============================================================

model Attachment {
  id            String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  deliverableId String   @map("deliverable_id") @db.Uuid
  name          String   @db.VarChar(255)
  url           String
  uploadedById  String?  @map("uploaded_by_id") @db.Uuid
  createdAt     DateTime @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  deliverable Deliverable @relation(fields: [deliverableId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  uploadedBy  Actor?      @relation("AttachmentUploadedBy", fields: [uploadedById], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([deliverableId], map: "idx_attachment_deliverable")
  @@index([uploadedById], map: "idx_attachment_uploaded_by")
  @@map("attachment")
  @@schema("public")
}

// ============================================================
// REVIEW
// ============================================================

model Review {
  id          String    @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  projectId   String    @map("project_id") @db.Uuid
  reviewDate  DateTime  @map("review_date") @db.Date
  notes       String
  createdById String    @map("created_by_id") @db.Uuid
  createdAt   DateTime  @default(now()) @map("created_at") @db.Timestamptz(6)
  modifiedAt  DateTime? @map("modified_at") @db.Timestamptz(6)
  deletedAt   DateTime? @map("deleted_at") @db.Timestamptz(6)
  version     Int       @default(1)

  // Relations
  createdBy Actor   @relation("ReviewCreatedBy", fields: [createdById], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project   Project @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([projectId], map: "idx_review_project", where: raw("(deleted_at IS NULL)"))
  @@index([projectId, reviewDate], map: "idx_review_date", where: raw("(deleted_at IS NULL)"))
  @@map("review")
  @@schema("public")
}

// ============================================================
// AUDIT LOG
// ============================================================

model AuditLog {
  id            String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  tableName     String      @map("table_name")
  recordId      String      @map("record_id") @db.Uuid
  action        AuditAction
  projectId     String?     @map("project_id") @db.Uuid
  taskId        String?     @map("task_id") @db.Uuid
  oldData       Json?       @map("old_data")
  newData       Json?       @map("new_data")
  changedFields Json?       @map("changed_fields")
  actorId       String?     @map("actor_id") @db.Uuid
  createdAt     DateTime    @default(now()) @map("created_at") @db.Timestamptz(6)

  // Relations
  actor   Actor?   @relation(fields: [actorId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  project Project? @relation(fields: [projectId], references: [id], onDelete: NoAction, onUpdate: NoAction)
  task    Task?    @relation(fields: [taskId], references: [id], onDelete: NoAction, onUpdate: NoAction)

  @@index([projectId, createdAt(sort: Desc)], map: "idx_audit_project_id")
  @@index([taskId, createdAt(sort: Desc)], map: "idx_audit_task_id")
  @@index([tableName, recordId], map: "idx_audit_record")
  @@index([actorId], map: "idx_audit_actor")
  @@index([createdAt(sort: Desc)], map: "idx_audit_created")
  @@map("audit_log")
  @@schema("public")
}
